# ╔══════════════════════════════════════════════════════════════════╗
# ║  TrafficGenius — DEVELOPMENT Environment Variables              ║
# ║  Domain: http://localhost:3080                                  ║
# ║                                                                 ║
# ║  This file is loaded automatically by Next.js and overrides     ║
# ║  .env values locally. Copy from .env.example and fill secrets.  ║
# ║  NEVER commit this file — it is in .gitignore.                  ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── Auth (NextAuth.js v5) ───────────────────────────────────────
AUTH_SECRET=<your-dev-secret-here>
AUTH_GOOGLE_ID=<your-google-client-id>
AUTH_GOOGLE_SECRET=<your-google-client-secret>
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:3080

# ─── Cloud SQL PostgreSQL ────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/traffic_genius?sslmode=require

# ─── GCP Configuration ──────────────────────────────────────────
GCP_PROJECT_ID=<your-gcp-project-id>
GOOGLE_APPLICATION_CREDENTIALS=<path-to-service-account-key.json>

# ─── BigQuery ────────────────────────────────────────────────────
BIGQUERY_DATASET=traffic_security_logs
BIGQUERY_TABLE=ivt_classifications

# ─── Cloud Armor ─────────────────────────────────────────────────
CLOUD_ARMOR_REGION=global

# ─── Logging ─────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_LOGGING=true

# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3080
